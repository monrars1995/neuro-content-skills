# ============================================================
# NEURO CONTENT SKILLS - CREDENCIAIS DO CLIENTE
# Arquivo: ~/conteudo/campanhas/{cliente}/.env.cliente
# ATENCAO: NUNCA commite este arquivo! Esta no .gitignore.
# ============================================================
# Preencha APENAS as APIs que vai usar.
# Deixe as outras com valor vazio.
# ============================================================

# ── TIKTOK ──────────────────────────────────────────────────
# Content Posting API (necessario para: /publicar)
# Como obter: https://developers.tiktok.com → Criar App → Content Posting
# Scopes necessarios: video.upload, video.publish
TIKTOK_ACCESS_TOKEN=
TIKTOK_APP_ID=
TIKTOK_USERNAME=

# Research API (necessario para: /trends, /metricas, /concorrentes)
# Como obter: Mesmo App do TikTok → Ativar Research API
TIKTOK_RESEARCH_API_KEY=
TIKTOK_BUSINESS_ID=

# ── INSTAGRAM / META ────────────────────────────────────────
# Graph API (necessario para: /publicar, /metricas)
# Como obter: https://developers.facebook.com → App Business → Instagram
META_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# Ads API (necessario para: /concorrentes - Meta Ads Library)
META_AD_ACCOUNT_ID=

# ── OPENAI ──────────────────────────────────────────────────
# Whisper API (necessario para: /legendas via API)
# Alternativa: instale Whisper local (pip3 install openai-whisper)
# Como obter: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── ELEVENLABS ─────────────────────────────────────────────
# TTS + Musica + Efeitos (necessario para: /voz, /musica, /efeitos, /mixar)
# Como obter: https://elevenlabs.io → Settings → API Keys
# Free tier: 10.000 caracteres/mes
ELEVENLABS_API_KEY=

# Voz padrao para TTS (escolha uma do /listar-vozes)
# Vozes recomendadas PT-BR:
#   Rachel    = 21m00Tcm4TlvDq8ikWAM  (natural, feminino - GERAL)
#   Adam      = pNInz6obpgDQGcFmaJgB  (profissional, masculino - EDUCACAO)
#   Charlotte = XB0fDUnXU5powFXDhCwa  (energetico, feminino - REELS)
#   Callum    = bIHbv24MWmeRgasZH58o  (jovem, masculino - VLOGS)
#   Antoni    = ErXwobaYiN019PkySvjV  (apresentador, masculino - PODCASTS)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Modelo TTS:
#   eleven_multilingual_v2 = melhor qualidade PT-BR (RECOMENDADO)
#   eleven_turbo_v2_5      = mais rapido, boa qualidade
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Formato de saida de audio:
#   mp3_44100_128 = padrao bom (RECOMENDADO)
#   mp3_44100_64  = menor tamanho
#   pcm_44100     = sem compressao (melhor para mixagem)
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── GOOGLE TRENDS ─────────────────────────────────────────
# Nao precisa de API key! Usa pytrends automaticamente.
# (necessario para: /trends, /create-editorial)
GOOGLE_TRENDS_GEO=BR
GOOGLE_TRENDS_LANG=pt

# ── WHISPER LOCAL (opcional) ──────────────────────────────
# Se preferir nao usar OpenAI API, instale Whisper localmente:
#   pip3 install openai-whisper
# Modelos disponiveis: tiny, base, small, medium, large
# tiny = mais rapido, menor precisao (~40MB)
# base = bom equilibrio (~75MB) - RECOMENDADO
# large = melhor precisao (~3GB), mais lento
# WHISPER_MODEL=base
# WHISPER_DEVICE=cpu
